
SERVICE_NAME="api-key-management"
SERVICE_PORT="8000"
SERVICE_URL="localhost"
LOG_LEVEL=INFO

KEY_PREFIX_TEST="sk_test"
KEY_PREFIX_DEV="sk_dev"
DEFAULT_KEY_LENGTH=32

POSTGRES_VERSION=16-alpine
POSTGRES_USER=apikey_user
POSTGRES_PASSWORD=apikey_pass
POSTGRES_DB=apikey_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}


